{
  "name": "myloyaltycards",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:watchos": "yarn watch:build",
    "test:all": "yarn test && yarn test:watchos",
    "watch:prebuild": "npx expo prebuild --clean --platform ios",
    "watch:build": "xcodebuild -workspace ios/myLoyaltyCards.xcworkspace -scheme watch -configuration Debug -destination \"generic/platform=watchOS Simulator\" build",
    "watch:build:ci": "xcodebuild -workspace ios/myLoyaltyCards.xcworkspace -scheme watch -configuration Debug -destination \"generic/platform=watchOS Simulator\" build",
    "watch:run": "yarn watch:build && WATCH_SIM=$(xcrun simctl list devices booted | awk -F '[()]' '/com.apple.CoreSimulator.SimRuntime.watchOS/ { gsub(/^ +| +$/,\"\",$1); print $1; exit }') && [ -n \"$WATCH_SIM\" ] || (echo 'No booted Apple Watch simulator found. Boot one in Simulator.app and retry.' && exit 1) && BUILT_DIR=$(xcodebuild -workspace ios/myLoyaltyCards.xcworkspace -scheme watch -configuration Debug -destination \"generic/platform=watchOS Simulator\" -showBuildSettings 2>/dev/null | awk '/ BUILT_PRODUCTS_DIR =/ {print $3; exit}') && xcrun simctl install \"$WATCH_SIM\" \"$BUILT_DIR/watch.app\" && xcrun simctl launch \"$WATCH_SIM\" com.iferoporefi.myloyaltycards.watch",
    "ios:watch": "yarn ios && yarn watch:run",
    "supabase:start": "npx supabase start",
    "supabase:stop": "npx supabase stop",
    "supabase:status": "npx supabase status",
    "supabase:reset": "npx supabase db reset",
    "supabase:functions:serve": "npx supabase functions serve --env-file supabase/.env.local",
    "supabase:functions:deploy": "npx supabase functions deploy delete-account",
    "prepare": "husky"
  },
  "dependencies": {
    "@bacons/apple-targets": "^4.0.6",
    "@bwip-js/react-native": "^4.8.0",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.5.2",
    "@react-native-picker/picker": "2.11.4",
    "@shopify/flash-list": "2.0.2",
    "@supabase/supabase-js": "^2.98.0",
    "burnt": "^0.13.0",
    "expo": "^55.0.19",
    "expo-brightness": "~55.0.13",
    "expo-camera": "~55.0.16",
    "expo-clipboard": "~55.0.13",
    "expo-constants": "~55.0.15",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "~55.0.17",
    "expo-haptics": "~55.0.14",
    "expo-linking": "~55.0.14",
    "expo-router": "~55.0.13",
    "expo-secure-store": "~55.0.13",
    "expo-sharing": "~55.0.18",
    "expo-sqlite": "~55.0.15",
    "expo-status-bar": "~55.0.5",
    "expo-updates": "~55.0.21",
    "nativewind": "4.2.1",
    "react": "19.2.0",
    "react-hook-form": "^7.70.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-watch-connectivity": "^1.1.0",
    "react-native-worklets": "0.7.4",
    "uuid": "^13.0.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.10",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^5.3.1",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.16",
    "lint-staged": "^16.2.7",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "react-native-svg-transformer": "^1.5.3",
    "supabase": "^2.76.15",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.9.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "private": true
}
