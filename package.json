{
  "name": "myloyaltycards",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "preios": "node scripts/ensure-expo-sqlite-vendor-files.mjs",
    "web": "expo start --web",
    "fastlane:match": "./scripts/fastlane-match.sh",
    "fastlane:match:bootstrap": "./scripts/fastlane-match.sh bootstrap",
    "fastlane:match:fetch": "./scripts/fastlane-match.sh fetch",
    "fastlane:match:development": "./scripts/fastlane-match.sh sync development",
    "fastlane:match:adhoc": "./scripts/fastlane-match.sh sync adhoc",
    "fastlane:match:appstore": "./scripts/fastlane-match.sh sync appstore",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "tokens:build": "node scripts/build-tokens.mjs",
    "tokens:check": "node scripts/build-tokens.mjs --check",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:watchos": "yarn watch:build",
    "test:all": "yarn test && yarn test:watchos",
    "watch:catalogue:generate": "xcrun --sdk macosx swift watch-ios/Scripts/generate-catalogue.swift",
    "check:catalogue-generated": "xcrun --sdk macosx swift watch-ios/Scripts/generate-catalogue.swift --check",
    "watch:prebuild": "npx expo prebuild --clean --platform ios",
    "prewatch:build": "node scripts/ensure-expo-sqlite-vendor-files.mjs && yarn watch:catalogue:generate",
    "watch:build": "./scripts/watch-build.sh",
    "prewatch:build:ci": "node scripts/ensure-expo-sqlite-vendor-files.mjs && yarn watch:catalogue:generate",
    "watch:build:ci": "xcodebuild -workspace ios/myLoyaltyCards.xcworkspace -scheme watch -configuration Debug -destination \"generic/platform=watchOS Simulator\" COMPILER_INDEX_STORE_ENABLE=NO build",
    "prewatch:run": "node scripts/ensure-expo-sqlite-vendor-files.mjs && yarn watch:catalogue:generate",
    "watch:run": "yarn watch:build && ./scripts/watch-run.sh",
    "ios:watch": "yarn ios && yarn watch:run",
    "supabase:start": "npx supabase start",
    "supabase:stop": "npx supabase stop",
    "supabase:status": "npx supabase status",
    "supabase:reset": "npx supabase db reset",
    "supabase:functions:serve": "npx supabase functions serve --env-file supabase/.env.local",
    "supabase:functions:deploy": "npx supabase functions deploy delete-account",
    "postinstall": "node scripts/ensure-expo-sqlite-vendor-files.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@bacons/apple-targets": "^4.0.6",
    "@bwip-js/react-native": "^4.8.0",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.5.2",
    "@react-native-picker/picker": "2.11.4",
    "@sentry/react-native": "~7.11.0",
    "@shopify/flash-list": "2.0.2",
    "@supabase/supabase-js": "^2.98.0",
    "burnt": "^0.13.0",
    "expo": "^55.0.19",
    "expo-brightness": "~55.0.13",
    "expo-build-properties": "~55.0.13",
    "expo-camera": "~55.0.16",
    "expo-clipboard": "~55.0.13",
    "expo-constants": "~55.0.15",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "~55.0.17",
    "expo-haptics": "~55.0.14",
    "expo-image-picker": "~55.0.19",
    "expo-linking": "~55.0.14",
    "expo-localization": "~55.0.15",
    "expo-router": "~55.0.13",
    "expo-secure-store": "~55.0.13",
    "expo-sharing": "~55.0.18",
    "expo-sqlite": "~55.0.15",
    "expo-status-bar": "~55.0.5",
    "expo-updates": "~55.0.21",
    "i18next": "^26.3.0",
    "react": "19.2.0",
    "react-hook-form": "^7.70.0",
    "react-i18next": "^17.0.8",
    "react-native": "0.83.6",
    "react-native-edge-to-edge": "^1.8.1",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-image-code-scanner": "^1.1.3",
    "react-native-nitro-modules": "^0.35.9",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-unistyles": "^3",
    "react-native-watch-connectivity": "^1.1.0",
    "react-native-worklets": "0.7.4",
    "uuid": "^13.0.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.10",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "better-sqlite3": "^12.10.0",
    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^5.3.1",
    "eslint-plugin-i18next": "^6.1.4",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.16",
    "lint-staged": "^16.2.7",
    "prettier": "^3.2.5",
    "react-native-svg-transformer": "^1.5.3",
    "style-dictionary": "^5.5.0",
    "supabase": "^2.76.15",
    "typescript": "~5.9.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "resolutions": {
    "string-length/strip-ansi": "6.0.1",
    "jest-message-util/strip-ansi": "6.0.1",
    "string-width": "^4.2.3"
  },
  "private": true
}
