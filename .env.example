# =============================================================================
# Supabase Configuration (Story 6-1)
# =============================================================================
# 
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in your actual values from Supabase Dashboard > Project Settings > API
# 3. NEVER commit .env to the repository (it's in .gitignore)
#
# IMPORTANT: EXPO_PUBLIC_ Prefix
# --------------------------------
# Expo only exposes environment variables to the client that start with EXPO_PUBLIC_
# Variables without this prefix will be undefined in the app.
# Learn more: https://docs.expo.dev/guides/environment-variables/
# 
# SECURITY NOTE:
# ---------------
# The anon (public) key is safe to use in client-side code because 
# Row Level Security (RLS) policies protect your data in Supabase.
# =============================================================================

# Supabase Project URL
# Get this from: Supabase Dashboard > Project Settings > API > Project URL
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon (Public) Key
# Get this from: Supabase Dashboard > Project Settings > API > Project API keys > anon public
EXPO_PUBLIC_SUPABASE_KEY=your-anon-key-here

# =============================================================================
# Sentry Error Reporting (Story 16-2)
# =============================================================================
# Public client DSN for crash/error reporting (required for Sentry to report).
# A DSN is not a secret (it ships in the client bundle), but it is read from env
# so builds can target different projects. When unset, Sentry disables sending.
# Get the real value from: Sentry > Settings > Projects > [project] > Client Keys (DSN).
EXPO_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.de.sentry.io/0
#
# CI-only (NOT EXPO_PUBLIC_ — must never ship in the client bundle): auth token
# used by the Sentry Expo plugin to upload source maps during release builds.
# SENTRY_AUTH_TOKEN=your-auth-token-here

# =============================================================================
# Session Storage (Story 6-3)
# =============================================================================
# Sessions are persisted securely via expo-secure-store (Keychain on iOS,
# Android Keystore on Android). No additional env vars required.
# Token refresh is handled automatically by @supabase/supabase-js.
# For troubleshooting, see docs/sprint-artifacts/manual-supabase-steps-6-1.md

