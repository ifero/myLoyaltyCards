default_platform(:ios)

app_identifier = CredentialsManager::AppfileConfig.try_fetch_value(:app_identifier)
watch_identifier = "#{app_identifier}.watch"
# The watch complication is a WidgetKit extension embedded in the watch app. It
# carries the App Groups entitlement, so it needs its own explicit App ID and
# match profile (a wildcard App ID can't hold App Groups).
widget_identifier = "#{watch_identifier}.widget"

def matched_profile_mapping(*bundle_ids)
  mapping = lane_context[Fastlane::Actions::SharedValues::MATCH_PROVISIONING_PROFILE_MAPPING] || {}

  bundle_ids.each_with_object({}) do |bundle_id, profiles|
    matched_profile = mapping[bundle_id]
    UI.user_error!("Missing match provisioning profile for #{bundle_id}") unless matched_profile

    profiles[bundle_id] = matched_profile
  end
end

platform :ios do
  before_all do
    # Creates a temporary keychain for match on CI runners.
    # No-op when running locally (unless force: true).
    setup_ci if is_ci
  end

  # Resolves match profiles for the iOS app, the watch app, and the watch
  # widget extension, applies manual code-signing to each target, and returns
  # the bundle-id => profile-name mapping for build_app's export options.
  # All distribution lanes go through here so a target can never be forgotten.
  private_lane :apply_distribution_signing do |options|
    targets_by_identifier = {
      app_identifier => "myLoyaltyCards",
      watch_identifier => "watch",
      widget_identifier => "watchwidget"
    }

    targets_by_identifier.each_key do |bundle_id|
      match(type: options[:match_type], app_identifier: bundle_id, readonly: is_ci)
    end

    profile_mapping = matched_profile_mapping(*targets_by_identifier.keys)

    targets_by_identifier.each do |bundle_id, target_name|
      update_code_signing_settings(
        use_automatic_signing: false,
        path: "ios/myLoyaltyCards.xcodeproj",
        team_id: ENV['FASTLANE_TEAM_ID'],
        profile_name: profile_mapping.fetch(bundle_id),
        code_sign_identity: "iPhone Distribution",
        targets: [target_name]
      )
    end

    profile_mapping
  end

  desc "Fetch certificates (appstore, adhoc, development)"
  lane :fetch_certificates do
    [app_identifier, watch_identifier, widget_identifier].each do |id|
      match(
        type: 'development',
        app_identifier: id
      )
      match(
        type: 'adhoc',
        app_identifier: id
      )
      match(
        type: 'appstore',
        app_identifier: id
      )
    end
  end

  desc "Build iOS Dev app"
  lane :build_dev do
    build_app(
      scheme: "myLoyaltyCards",
      export_method: "development",
      xcargs: "DEVELOPMENT_TEAM='#{ENV['FASTLANE_TEAM_ID']}'"
    )
  end

  desc "Build iOS AdHoc app"
  lane :adhoc do
    api_key = app_store_connect_api_key(
      key_id: ENV['APP_STORE_CONNECT_API_KEY_KEY_ID'],
      issuer_id: ENV['APP_STORE_CONNECT_API_KEY_ISSUER_ID'],
      key_content: ENV['APP_STORE_CONNECT_API_KEY_KEY'],
      in_house: false
    )

    # Sign the iOS app, watch app, and watch widget extension, then export with
    # the exact profile names resolved by match.
    profile_mapping = apply_distribution_signing(match_type: "adhoc")

    # Use CI run number for a guaranteed-unique, ever-increasing build number.
    # Falls back to Unix timestamp when running locally.
    build_number = ENV['GITHUB_RUN_NUMBER'] || Time.now.to_i.to_s
    increment_build_number(
      xcodeproj: "ios/myLoyaltyCards.xcodeproj",
      build_number: build_number
    )
    build_app(
      scheme: "myLoyaltyCards",
      workspace: "ios/myLoyaltyCards.xcworkspace",
      export_method: "ad-hoc",
      output_directory: "output",
      export_options: {
        provisioningProfiles: profile_mapping
      },
      xcargs: "DEVELOPMENT_TEAM='#{ENV['FASTLANE_TEAM_ID']}'"
    )
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV['APP_STORE_CONNECT_API_KEY_KEY_ID'],
      issuer_id: ENV['APP_STORE_CONNECT_API_KEY_ISSUER_ID'],
      key_content: ENV['APP_STORE_CONNECT_API_KEY_KEY'],
      in_house: false
    )

    profile_mapping = apply_distribution_signing(match_type: "appstore")

    # Retrieve last build number from TestFlight and increment
    last_build = latest_testflight_build_number(
      app_identifier: app_identifier,
      api_key: api_key
    )
    increment_build_number(
      xcodeproj: "ios/myLoyaltyCards.xcodeproj",
      build_number: (last_build.to_i + 1).to_s
    )
    build_app(
      scheme: "myLoyaltyCards",
      workspace: "ios/myLoyaltyCards.xcworkspace",
      export_method: "app-store",
      output_directory: "output",
      export_options: {
        provisioningProfiles: profile_mapping
      },
      xcargs: "DEVELOPMENT_TEAM='#{ENV['FASTLANE_TEAM_ID']}'"
    )
    upload_to_testflight(
      api_key: api_key
    )
  end

  desc "Build and upload to App Store Connect (release)"
  lane :upload_release do
    api_key = app_store_connect_api_key(
      key_id: ENV['APP_STORE_CONNECT_API_KEY_KEY_ID'],
      issuer_id: ENV['APP_STORE_CONNECT_API_KEY_ISSUER_ID'],
      key_content: ENV['APP_STORE_CONNECT_API_KEY_KEY'],
      in_house: false
    )

    profile_mapping = apply_distribution_signing(match_type: "appstore")

    build_number = ENV['GITHUB_RUN_NUMBER'] || Time.now.to_i.to_s
    increment_build_number(
      xcodeproj: "ios/myLoyaltyCards.xcodeproj",
      build_number: build_number
    )
    build_app(
      scheme: "myLoyaltyCards",
      workspace: "ios/myLoyaltyCards.xcworkspace",
      export_method: "app-store",
      output_directory: "output",
      export_options: {
        provisioningProfiles: profile_mapping
      },
      xcargs: "DEVELOPMENT_TEAM='#{ENV['FASTLANE_TEAM_ID']}'"
    )
    upload_to_app_store(
      api_key: api_key,
      skip_metadata: true,
      skip_screenshots: true,
      precheck_include_in_app_purchases: false
    )
  end
end

platform :android do
  package_name = ENV['ANDROID_PACKAGE_NAME'] || CredentialsManager::AppfileConfig.try_fetch_value(:package_name)
  json_key_data = ENV['PLAY_STORE_API_KEY']

  desc "Build Android Dev app"
  lane :build_dev do
    gradle(task: "assembleDebug", project_dir: "android")
  end

  desc "Build Android AdHoc app"
  lane :adhoc do
    # Use short commit hash as versionCode
    commit_hash = sh("git rev-parse --short HEAD").strip
    version_code = commit_hash.hex % 2147483647 # Android max int
    gradle(
      task: "assembleRelease",
      project_dir: "android",
      properties: {
        "android.injected.version.code" => version_code,
        "android.injected.signing.store.file" => ENV['ANDROID_KEYSTORE_PATH'],
        "android.injected.signing.store.password" => ENV['ANDROID_KEYSTORE_PASSWORD'],
        "android.injected.signing.key.alias" => ENV['ANDROID_KEY_ALIAS'],
        "android.injected.signing.key.password" => ENV['ANDROID_KEY_PASSWORD']
      }
    )
  end

  desc "Build and upload to Play Console (alpha)"
  lane :beta do
    UI.user_error!("Missing ANDROID_PACKAGE_NAME") unless package_name
    UI.user_error!("Missing PLAY_STORE_API_KEY") unless json_key_data

    # Retrieve last versionCode from Play Console and increment
    last_version_code = google_play_track_version_codes(
      package_name: package_name,
      track: 'alpha',
      json_key_data: json_key_data
    ).max || 1
    gradle(
      task: "bundleRelease",
      project_dir: "android",
      properties: {
        "android.injected.version.code" => last_version_code + 1,
        "android.injected.signing.store.file" => ENV['ANDROID_KEYSTORE_PATH'],
        "android.injected.signing.store.password" => ENV['ANDROID_KEYSTORE_PASSWORD'],
        "android.injected.signing.key.alias" => ENV['ANDROID_KEY_ALIAS'],
        "android.injected.signing.key.password" => ENV['ANDROID_KEY_PASSWORD']
      }
    )
    upload_to_play_store(
      package_name: package_name,
      json_key_data: json_key_data,
      track: "alpha",
      release_status: "draft",
      aab: "android/app/build/outputs/bundle/release/app-release.aab",
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
  end

  desc "Build and upload to Play Store (release)"
  lane :upload_release do
    UI.user_error!("Missing ANDROID_PACKAGE_NAME") unless package_name
    UI.user_error!("Missing PLAY_STORE_API_KEY") unless json_key_data

    last_version_code = google_play_track_version_codes(
      package_name: package_name,
      track: 'production',
      json_key_data: json_key_data
    ).max || 1
    gradle(
      task: "bundleRelease",
      project_dir: "android",
      properties: {
        "android.injected.version.code" => last_version_code + 1,
        "android.injected.signing.store.file" => ENV['ANDROID_KEYSTORE_PATH'],
        "android.injected.signing.store.password" => ENV['ANDROID_KEYSTORE_PASSWORD'],
        "android.injected.signing.key.alias" => ENV['ANDROID_KEY_ALIAS'],
        "android.injected.signing.key.password" => ENV['ANDROID_KEY_PASSWORD']
      }
    )
    upload_to_play_store(
      package_name: package_name,
      json_key_data: json_key_data,
      track: "production",
      aab: "android/app/build/outputs/bundle/release/app-release.aab",
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
  end
end
